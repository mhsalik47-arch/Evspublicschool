rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == "mhsalik47@gmail.com" && isEmailVerified();
    }

    // Action Helpers
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Roles (used in create/update mostly to avoid get() in list)
    function isAdmin() {
      return isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // Rules for Collections
    
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /students/{studentId} {
      allow read: if isSignedIn(); // All staff/admins can read students
      allow create: if isSignedIn(); 
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /fees/{feeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow read: if isSignedIn();
      allow create: if true; // Public
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      // Expenses are sensitive, but we want staff to avoid errors even if they can't see the tab
      // However, the tab is hidden. Let's allow read if admin.
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /attendance/{attId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /scores/{scoreId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isSignedIn(); // Staff can see visitor messages
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }
  }
}
