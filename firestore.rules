rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, role (admin/staff), createdAt
    //
    // Collection: students
    // Fields: id, fullName, parentName, parentPhone, class, registeredBy, registrationDate, status
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function userDocExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        ((userDocExists() && getUserData().role == 'admin') || 
         (request.auth.token.email == "mhsalik47@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isStaff() {
      return isAuthenticated() && (isAdmin() || (userDocExists() && getUserData().role == 'staff'));
    }

    // Validation Functions
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role']) &&
             (data.keys().hasAny(['email', 'phoneNumber'])) &&
             data.role in ['admin', 'staff'] &&
             data.uid == request.auth.uid;
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['fullName', 'parentPhone', 'class', 'registeredBy']) &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() < 100 &&
             data.parentPhone is string && data.parentPhone.matches('^[0-9]{10,15}$') &&
             data.registeredBy == request.auth.uid;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['studentName', 'mobile1', 'applyingFor', 'status']) &&
             data.status in ['new', 'contacted', 'enrolled'] &&
             data.studentName is string && data.studentName.size() > 0 &&
             data.mobile1 is string && data.mobile1.size() > 0;
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'staff' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /students/{studentId} {
      allow read: if isAdmin() || (isStaff() && resource.data.registeredBy == request.auth.uid);
      allow create: if isStaff() && isValidStudent(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow read: if isAdmin() || (isStaff() && resource.data.assignedStaffId == request.auth.uid);
      allow create: if true; // Public inquiry form
      allow update: if isAdmin() || (isStaff() && resource.data.assignedStaffId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /fees/{feeId} {
      allow read: if isAdmin() || (isStaff() && resource.data.collectedBy == request.auth.uid);
      allow create: if isStaff();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if true; // Public can see activities
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if true;
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read, update, delete: if isStaff();
      allow create: if true; // Public contact form
    }

    match /notifications/{notifId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}
